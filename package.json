{
  "name": "d1vij-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:hash-history": "tsc -b && VITE_USE_HASH_HISTORY=true vite build",
    "preview": "vite preview",
    "format": "biome format --write src/",
    "lint": "biome check --write --unsafe",
    "typecheck": "tsc -b",
    "generate:schemas": "bun run src/generate_schema.ts",
    "stats": "bun run dist/stats.html",
    "prepare": "husky"
  },
  "dependencies": {
    "-": "^0.0.1",
    "@d1vij/jassm": "^0.1.24",
    "@d1vij/shit-i-always-use": "^0.1.14",
    "@tanstack/react-router": "^1.168.8",
    "lucide-react": "^0.576.0",
    "radashi": "^12.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-vite-plugin": "^1.166.24",
    "@types/bun": "^1.3.11",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@valibot/to-json-schema": "^1.6.0",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
